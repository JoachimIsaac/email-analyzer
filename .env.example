# PostgreSQL (docker-compose defaults)
POSTGRES_DB=emailanalyzer
POSTGRES_USER=emailanalyzer
POSTGRES_PASSWORD=emailanalyzer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-in-production
FIELD_ENCRYPTION_KEY=generate-with-python-cryptography-fernet
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL (used for post-OAuth redirect)
FRONTEND_URL=http://localhost:5173

# OpenAI
OPENAI_API_KEY=sk-your-key-here
